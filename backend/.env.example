# ============================================================
#  Bin Aouf — backend environment TEMPLATE (.env.example)
#  Copy this file to '.env' and fill in your real values.
#  DO NOT commit your real '.env' file to Git!
# ============================================================

NODE_ENV=development
PORT=4000

# Public URL of the backend (used to build absolute image URLs)
PUBLIC_URL=http://localhost:4000

# ─── Database (MongoDB Atlas) ───────────────────────────────
# Paste your real MongoDB Atlas connection string here.
# Format example: mongodb://<username>:<password>@host1:27017,host2:27017/binaouf?ssl=true&replicaSet=<set-name>&authSource=admin
MONGO_URI=mongodb://<db_username>:<db_password>@ac-xxxxxx-shard-00-00.sd5diag.mongodb.net:27017/binaouf?ssl=true&replicaSet=atlas-xxxxxx-shard-0&authSource=admin

# ─── Auth ───────────────────────────────────────────────────
# Use a long, random hex string (e.g. generated via `openssl rand -hex 64`)
JWT_SECRET=<your_secure_jwt_secret_key>
JWT_EXPIRES_IN=7d

# ─── Admin Seed Credentials ──────────────────────────────────
ADMIN_NAME=Roman Amjid
ADMIN_EMAIL=admin@binaouf.com
ADMIN_PASSWORD=<your_strong_admin_password>

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of origins allowed to request this API
CORS_ORIGINS=http://localhost:5173,https://binaouf.com,https://www.binaouf.com

# ─── File Upload Limits ──────────────────────────────────────
MAX_UPLOAD_MB=5

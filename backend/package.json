{
  "name": "binaouf-backend",
  "version": "1.0.0",
  "description": "Production REST API for the Bin Aouf Himalayan salt export site + admin panel (Node.js, Express, MongoDB).",
  "type": "module",
  "main": "src/server.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "seed": "node src/seed/seed.js",
    "seed:fresh": "node src/seed/seed.js --fresh"
  },
  "keywords": [
    "binaouf",
    "express",
    "mongodb",
    "rest-api"
  ],
  "author": "Roman Amjid",
  "license": "UNLICENSED",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.9.5",
    "morgan": "^1.10.0",
    "multer": "^2.2.0",
    "zod": "^3.24.1"
  }
}
